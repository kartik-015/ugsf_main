# MongoDB Database URL
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# NextAuth Secret Key
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters long
# NEVER commit the actual key, only this placeholder
NEXTAUTH_SECRET=

# NextAuth URL (used for callbacks)
# Local development: http://localhost:3000
# Production: https://yourdomain.vercel.app
NEXTAUTH_URL=

# Environment
# Development: development
# Production: production
NODE_ENV=production

# Optional: Email Configuration
# If you want to enable credential emails
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Optional: Cloudinary Configuration (file uploads)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
